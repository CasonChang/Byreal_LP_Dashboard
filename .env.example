# ── 必填 ───────────────────────────────────────────────
# 你要追蹤的 Solana 錢包地址（可多個，用逗號分隔）
WALLET_ADDRESS=FPa1NnUpG89LpHLnKAPrNrxksVZWrjcpNAqnXiwpoqYn

# Telegram 推播（向 @BotFather 申請 bot 取得 token；用 @userinfobot 取得你的 chat id）
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=123456789

# Supabase（專案 Settings → API；寫入請用 service_role key）
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── 選填（有預設值）────────────────────────────────────
# Byreal API base（一般不用改）
BYREAL_API_URL=https://api2.byreal.io
# 快出界警示門檻：距離最近區間邊界小於此百分比就提醒（預設 8%）
RANGE_WARN_PCT=8
# 報告時區
TZ=Asia/Taipei
# 測試用：true 時不送 Telegram、不寫 Supabase，只印出結果
DRY_RUN=false
